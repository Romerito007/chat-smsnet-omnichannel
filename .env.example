# ── Process role ────────────────────────────────────────────────────────────
# all | api | ws | worker | scheduler
RUN_ROLE=all
APP_ENV=development
LOG_LEVEL=info
# Dev-only: log the (redacted, truncated 4KB) request body + error code/message
# per request. Credentials (password, *_token, *_secret, api_key, Authorization)
# are ALWAYS redacted. Keep false in production.
LOG_REQUEST_BODY=false

# ── HTTP / WS ───────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=20s
# Comma-separated; "*" allows any origin.
HTTP_ALLOWED_ORIGINS=*

# GET /openapi.json is public in development. In production it is behind HTTP
# basic auth: set both to enable access (left empty in prod locks the endpoint).
OPENAPI_BASIC_USER=
OPENAPI_BASIC_PASS=

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=chat

# ── Redis (cache, presence, locks, rate limit, pub/sub, Asynq) ──────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Asynq queues ────────────────────────────────────────────────────────────
ASYNQ_CONCURRENCY=20
ASYNQ_QUEUE_CRITICAL=6
ASYNQ_QUEUE_DEFAULT=3
ASYNQ_QUEUE_CHANNELS=3
ASYNQ_QUEUE_WEBHOOKS=2
ASYNQ_QUEUE_AI=2
ASYNQ_QUEUE_REPORTS=1

# ── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=chat-backend

# ── Auth (JWT + password) ───────────────────────────────────────────────────
# AUTH_JWT_SECRET MUST be set to a strong value in production.
AUTH_JWT_SECRET=dev-secret-change-me
AUTH_ISSUER=chat-backend
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h
AUTH_BCRYPT_COST=12

# ── Channels ────────────────────────────────────────────────────────────────
# Encrypts channel credentials at rest. Set a strong value in production.
CHANNELS_ENCRYPTION_KEY=dev-channel-encryption-key
# Max simultaneous WebSocket connections per user (0 = unlimited).
WS_MAX_CONN_PER_USER=10

# ── Automation (external flow) ──────────────────────────────────────────────
# Public base URL the external flow uses to call back.
AUTOMATION_CALLBACK_BASE_URL=http://localhost:8080

# ── ProviderHub (standardized provider API gateway) ─────────────────────────
# Max on-demand provider queries per tenant per minute.
PROVIDERHUB_RATE_PER_MINUTE=60

# ── SMSNET Integrations (env defaults; per-tenant DB config overrides) ───────
# HTTP gateway used by ProviderHub when a tenant has no own config. The key is
# read only in the backend and is NEVER returned to the front.
ISP_GATEWAY_API_HOST=
ISP_GATEWAY_API_KEY=
# MCP servers (JSON-RPC over Streamable HTTP). PRIVATE NETWORK ONLY — no auth.
# Never expose these ports to the internet. Read = no approval; Write = always
# human-approval (pending mcp_approval).
SMSNET_MCP_CONSULTAS_URL=
SMSNET_MCP_OPERACOES_URL=

# ── Copilot (AI provider) ───────────────────────────────────────────────────
# Provider API keys are configured PER TENANT (encrypted at rest) via
# PATCH /v1/copilot/config — not via env. The variables below are deprecated and
# unused by the provider wiring; keep them empty.
COPILOT_OPENAI_API_KEY=
COPILOT_GEMINI_API_KEY=
COPILOT_ANTHROPIC_API_KEY=

# ── Notifications ───────────────────────────────────────────────────────────
# From address for notification emails, and base URL for in-app deep links
# (also used to build verification/invite/reset links sent by the account flows).
NOTIFICATIONS_EMAIL_FROM=no-reply@example.com
APP_BASE_URL=http://localhost:3000

# ── Email / SMTP (real transport) ───────────────────────────────────────────
# Used by both the notification email channel and the account flows (signup
# verification, invitation, password reset). Leave SMTP_HOST empty in local dev
# to disable sending; any send will then fail loudly (there is no logging stub).
# SMTP_TLS_MODE: starttls (opportunistic, 587) | tls (implicit, 465) | none.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_TLS_MODE=starttls

# ── Account tokens (single-use, hashed at rest) ─────────────────────────────
# Lifetimes of the email-verification, password-reset and invitation tokens.
AUTH_VERIFICATION_TTL=24h
AUTH_PASSWORD_RESET_TTL=1h
AUTH_INVITE_TTL=72h

# ── CSAT (satisfaction surveys) ─────────────────────────────────────────────
# How long a sent survey waits for an answer, and the base URL for the public
# answer link sent to customers (defaults to APP_BASE_URL).
CSAT_EXPIRE_AFTER_SECONDS=259200
CSAT_PUBLIC_BASE_URL=http://localhost:3000

# ── Reports export (real CSV/JSON files + signed download URLs) ─────────────
# Where export files are written and how their temporary signed URLs are minted
# (SIGNING_SECRET defaults to AUTH_JWT_SECRET; DOWNLOAD_BASE_URL is the API origin).
REPORTS_STORAGE_DIR=/tmp/chat-reports
REPORTS_SIGNING_SECRET=
REPORTS_DOWNLOAD_BASE_URL=http://localhost:8080
REPORTS_DOWNLOAD_TTL=24h

# ── Media / attachment storage ──────────────────────────────────────────────
# Backend for message attachments: "local" (dev default) or "s3" (production).
# local serves bytes through the API via signed tokens; s3 issues presigned
# PUT/GET URLs so bytes flow directly between the client and the bucket.
STORAGE_PROVIDER=local
# Max attachment size in bytes (25 MiB).
ATTACHMENTS_MAX_SIZE_BYTES=26214400
# MIME allow-list, comma-separated, supports "image/*" (e.g. image/*,application/pdf).
# Leave empty to allow any content type. Do NOT put an inline "# comment" after the
# value on this line — it would be parsed as the value and break the allow-list.
ATTACHMENTS_ALLOWED_CONTENT_TYPES=
ATTACHMENTS_UPLOAD_TTL=15m
ATTACHMENTS_DOWNLOAD_TTL=5m
# local backend:
ATTACHMENTS_LOCAL_DIR=/tmp/chat-attachments
ATTACHMENTS_BASE_URL=http://localhost:8080
# s3 backend (used when STORAGE_PROVIDER=s3). Object keys are namespaced per
# tenant: attachments/{tenant_id}/{conversation_id}/{attachment_id}/{filename}.
S3_BUCKET=
S3_REGION=us-east-1
# Leave the AWS keys empty to use the default credential chain (env / shared
# config / IAM role on EC2/ECS) — recommended in production. Never logged.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3-compatible stores (MinIO, Cloudflare R2): set the endpoint + path-style.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
# Max lifetime of a presigned upload/download URL.
S3_PRESIGN_EXPIRY=300s

# ── Maintenance (periodic job limits; overridable per tenant via settings) ──
MAINTENANCE_INACTIVE_CLOSE_AFTER=24h
MAINTENANCE_NOTIFICATION_RETENTION=720h
MAINTENANCE_AUDIT_RETENTION=8760h

# ── First-boot seed (idempotent) ────────────────────────────────────────────
SEED_TENANT_NAME=Default Tenant
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_NAME=Owner
SEED_OWNER_PASSWORD=change-me-now

# ── Demo seed (NUNCA ligar em produção real) ────────────────────────────────
# Semeia dados demo no tenant do SEED_OWNER_EMAIL para popular todas as telas.
SEED_DEMO_DATA=false      # liga a semeadura de dados demo
SEED_DEMO_RESET=false     # apaga só os dados demo e recria (refresca as datas)
SEED_DEMO_PASSWORD=demo1234   # senha dos usuários demo criados (dev only)
